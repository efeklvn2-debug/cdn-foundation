# Server Configuration
PORT=3001
NODE_ENV=development

# Database (if using a database)
# DATABASE_URL=postgresql://username:password@localhost:5432/emerhana_foundation
# DATABASE_SSL=false

# EmailJS Configuration (for static site forms)
# Get these from https://www.emailjs.com/
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_DONATE_SERVICE_ID=your_donate_service_id
VITE_EMAILJS_DONATE_TEMPLATE_ID=your_donate_template_id
VITE_EMAILJS_CONTACT_SERVICE_ID=your_contact_service_id
VITE_EMAILJS_CONTACT_TEMPLATE_ID=your_contact_template_id

# Contact Email
CONTACT_EMAIL=info@emerhana-foundation.org

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://emerhana-foundation.org

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID
VITE_HOTJAR_ID=YOUR_HOTJAR_ID
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id